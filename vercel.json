{
  "crons": [
    {
      "path": "/api/threads-auto-post",
      "schedule": "0 13 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/monthly-saving-rate",
      "destination": "/index.html"
    }
  ]
}
