{
  "crons": [
    {
      "path": "/api/threads-auto-post",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/threads-auto-post?action=refresh-token",
      "schedule": "0 2 * * 1"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    },
    {
      "source": "/ads.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/monthly-saving-rate", "destination": "/index.html" },
    { "source": "/cash-runway", "destination": "/index.html" },
    { "source": "/travel-budget", "destination": "/index.html" },
    { "source": "/investment-allocation", "destination": "/index.html" },
    { "source": "/financial-freedom", "destination": "/index.html" },
    { "source": "/wealth-tier", "destination": "/index.html" },
    { "source": "/same-age-savings", "destination": "/index.html" },
    { "source": "/fixed-expense-ratio", "destination": "/index.html" },
    { "source": "/articles", "destination": "/index.html" },
    { "source": "/blog", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/privacy-policy", "destination": "/index.html" },
    { "source": "/disclaimer", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" }
  ]
}
